<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox DISABLED for debug/profile — allows flutter run to work correctly.
	     The sandbox blocks macOS's `open` command from re-foregrounding a running app,
	     which causes "Failed to foreground app; open returned 1" + connection drop.
	     Re-enable for production by copying the Release.entitlements settings. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<!-- JIT needed for Flutter debug mode -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<!-- Network for hot reload -->
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
